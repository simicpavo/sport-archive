# === Backend (Coolify resource) ===
DATABASE_URL=postgresql://user:password@coolify-db-host:5432/sport_archive
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://sportchronica.com
KEYCLOAK_ISSUER=https://auth.sportchronica.com/realms/sport-archive
KEYCLOAK_JWKS_URI=https://auth.sportchronica.com/realms/sport-archive/protocol/openid-connect/certs

# === Frontend (Coolify resource — build args) ===
API_URL=https://api.sportchronica.com/api
KEYCLOAK_URL=https://auth.sportchronica.com

# === Keycloak (Coolify resource) ===
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://coolify-db-host:5432/sport_archive?currentSchema=keycloak
KC_DB_USERNAME=user
KC_DB_PASSWORD=password
KC_HOSTNAME=auth.sportchronica.com
KC_PROXY_HEADERS=xforwarded
KC_HTTP_ENABLED=true
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your_secure_keycloak_admin_password
